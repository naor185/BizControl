# ── BizControl Production Environment Variables ───────────────────────────────
# Copy this to Railway / your server. Never commit real values to git.

# ── Database (Railway provides this automatically) ────────────────────────────
DATABASE_URL=postgresql+psycopg2://USER:PASS@HOST:PORT/DB

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30

# ── Superadmin ────────────────────────────────────────────────────────────────
ADMIN_SETUP_SECRET=change-this-secret
PLATFORM_SLUG=bizcontrol-platform

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your frontend domain)
ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# ── Platform Email (Gmail App Password) ──────────────────────────────────────
PLATFORM_SMTP_HOST=smtp.gmail.com
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_USER=your@gmail.com
PLATFORM_SMTP_PASS=your-app-password-16-chars
PLATFORM_SMTP_FROM=BizControl <your@gmail.com>
PLATFORM_ADMIN_EMAIL=your@gmail.com

# ── AI APIs (Optional) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=

# ── Uploads ───────────────────────────────────────────────────────────────────
# Optional: use cloud storage instead of local disk on Railway
# CLOUDINARY_URL=cloudinary://...
